HOME

;CALL TOOL TO SET
;T=".5BALL"
M6
D1

;SELECT WHICH TYPE OF SETTING
;GOTOF N1 ;LENGTH ONLY
;GOTOF N2 ;LENGTH AND RADIUS


N1 ;LENGTH ONLY
S3750 M3
D1
;NCG#BL9902A#bguilas.com#PRGCODE#*NCG;*RO*;*HD*
;##"0=Measure"##1#1#8##1#1####0.001969#0#2#0.000394#""#0#"\\"#""#"\\"#"png"#"png"#"png"#1#0##3##25.4#"0=Measure"#"\\bsk_cncl.png"#"\\bsk_ok.png"#2#1#0#"BL9902A"#*NCG;*RO*;*HD*
BL9902A(0,,0,2,0.000394,,0)
;#END#*NCG;*RO*;*HD*
GOTOF N9999

N2 ;LENGTH AND RADIUS
S3750 M3
D1
;NCG#BL9903#bguilas.com#PRGCODE#*NCG;*RO*;*HD*
;##"0=Measure"#"0=Length+radius"#"-1=L front, R 1side"#3####1##1#1#1#6#1#1#2######0.3#""#0.001969#0.001969#0#0.001969#0#0#2#0.0005#"\\"#""#"\\"#"png"#"png"#"png"#1#0##3##25.4#"0=Measure"#"0=Length+radius"#"-1=L front, R 1side"#"\\bsk_cncl.png"#"\\bsk_ok.png"#2#1#0#"BL9903"#*NCG;*RO*;*HD*
BL9903(0,0,-1,0.3,,,,0,,0,0,2,0.0005)
;#END#*NCG;*RO*;*HD*


N9999
HOME
M17
